__pycache__/
*.pyc
*.pyo
audio/

# Keep only SQLite's transient journal files local.  The canonical activity
# database and uploaded deck assets are versioned so another presentation PC
# can restore the same deck with a normal git pull.
data/*.db-shm
data/*.db-wal
data/*.db-journal

# 本地运行/调试产物
.env
server*.log
static/ocr_output/
static/thumbnails/
*.bak

# 编辑器上传的视频保留在演示电脑本地；GitHub 单文件上限为 100 MB。
# 已经被 Git 跟踪的历史小视频不受这些规则影响。
static/uploads/*.mp4
static/uploads/*.webm
static/uploads/*.ogg
static/uploads/*.mov
static/uploads/*.avi
static/uploads/*.mkv
static/uploads/*.m4v

# 本地大文件与种子源
temp.pptx

# 本地调试/一次性脚本（按需保留本地，不入库）
debug_*.py
check_html.py
fix_dataslide.py
test_p0_verify.py
verify_phase_d.py
check_editor.py
