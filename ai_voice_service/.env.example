ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_REALTIME_MODEL=glm-realtime-flash
ZHIPU_REALTIME_VOICE=tongtong

AI_VOICE_HOST=0.0.0.0
AI_VOICE_PORT=8100

# 允许把本服务嵌入 iframe 的 PPT 地址，多个地址以空格分隔。
AI_VOICE_ALLOWED_PARENT_ORIGINS=http://127.0.0.1:8000 http://localhost:8000

# 一般无需设置；仅当 WebSocket 客户端页面和AI服务不同源时才添加来源。
AI_VOICE_ALLOWED_CLIENT_ORIGINS=

# 单条浏览器 WebSocket 消息最大字节数。
AI_VOICE_MAX_WS_MESSAGE_BYTES=131072
